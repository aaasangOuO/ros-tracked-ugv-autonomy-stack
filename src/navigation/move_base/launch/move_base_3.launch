<launch>
  <!-- 启动 move_base -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find move_base)/config_811/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find move_base)/config_811/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find move_base)/config_811/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find move_base)/config_811/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find move_base)/config_811/move_base_params.yaml" command="load" />
    <param name="base_global_planner" value="global_planner/GlobalPlanner" />
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>
    <rosparam file="$(find move_base)/config_811/teb_local_planner_params.yaml" command="load" />
  </node>
  
  <node name="map_server" pkg="map_server" type="map_server" args="$(find scout_description)/maps/map_0812.yaml" output="screen">
    <!-- <param name="frame_id" value="map"/> -->
  </node>
  
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <!-- <rosparam file="$(find scout_description)/param/amcl_params.yaml" command="load" /> -->
  </node>

  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find scout_description)/rviz/mapping.rviz" />

</launch>